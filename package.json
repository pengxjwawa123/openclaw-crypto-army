{
  "name": "openclaw-control-center",
  "version": "1.0.0",
  "description": "Portainer-like control center for OpenClaw bot instances",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "tsx watch src/backend/index.ts",
    "dev:frontend": "cd frontend && pnpm exec vite",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:frontend": "cd frontend && pnpm exec vite build",
    "start": "node dist/backend/index.js",
    "docker:build": "docker build -t openclaw-control .",
    "setup": "pnpm install && cd frontend && pnpm install && cd .. && mkdir -p data"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dockerode": "^4.0.2",
    "dotenv": "^17.2.4",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "lowdb": "^7.0.1",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
