PORT=3000
NODE_ENV=development
DATA_DIR=./data

# Mnemonic for wallet generation (12 or 24 words)
# Each bot gets a unique private key derived from this mnemonic
MNEMONIC=your twelve word mnemonic phrase goes here for wallet generation

# OpenClaw Configuration
OPENCLAW_IMAGE_VERSION=2026.2.6-3
OPENCLAW_GATEWAY_URL=http://openclaw-gateway:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# Optional: Additional APT packages to install in OpenClaw container
OPENCLAW_DOCKER_APT_PACKAGES=

# Optional: Extra volume mounts for OpenClaw
OPENCLAW_EXTRA_MOUNTS=

# Network RPC URLs (optional - can be configured per bot)
ETH_RPC_URL=https://1rpc.io/sepolia

# Trading defaults (optional)
SLIPPAGE=0.5
GAS_LIMIT=500000
